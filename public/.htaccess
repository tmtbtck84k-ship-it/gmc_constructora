<IfModule mod_rewrite.c>
    Options -MultiViews
    RewriteEngine On

    # Si el archivo o directorio existe, servirlo
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Forzar HTTPS si la cabecera HTTPS no está presente (descomentar en prod)
    # RewriteCond %{HTTPS} !=on
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Bloquear acceso directo a estos paths
    RewriteRule ^(application|system|storage|application/config|application/migrations) - [F,L]

    # Pasar todo a index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Bloquear listado de directorios
Options -Indexes

# Cabeceras de seguridad básicas (Apache 2.4+)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Referrer-Policy "same-origin"
</IfModule>

# Compresión
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>
