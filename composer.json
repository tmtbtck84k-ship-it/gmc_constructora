{
    "name": "gmc/erp",
    "description": "ERP GMC - Modelo de Gestión Integral (Fase 1)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^6.9",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "autoload": {
        "psr-4": {
            "GMC\\": "application/services/"
        }
    }
}
